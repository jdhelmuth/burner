{
  "name": "burner-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev:mobile": "pnpm --filter burner-mobile dev",
    "dev:web": "pnpm --filter burner-web dev",
    "neon:migrate": "node scripts/run-neon-migrations.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
